# 端侧 ASR 插件产物（scripts/build-asr-plugin.sh 生成/下载）
addons/maliang_asr/bin
asr_plugin/libs/
asr_plugin/src/main/assets/
asr_plugin/build/
asr_plugin/.gradle/
asr_plugin/local.properties

# macOS/桌面端侧 ASR GDExtension 产物（scripts/build-asr-gdextension.sh 生成/下载）
# 不带尾斜杠：带斜杠只忽略「目录」，同名的 symlink 会漏网被 git add -A 吞进仓库
# （踩过：worktree 里指回主 checkout 的软链被提交，merge 时反过来覆盖并销毁了真实产物）
addons/maliang_asr_native/bin
gdextension_asr/godot-cpp/
gdextension_asr/sherpa-onnx/
gdextension_asr/extension_api.json
gdextension_asr/gdextension_interface.h
gdextension_asr/*.o
gdextension_asr/*.os
gdextension_asr/src/*.o
gdextension_asr/src/*.os

# 签名/公证材料（绝不入库；见 .keystores 同理）——防御性通配
