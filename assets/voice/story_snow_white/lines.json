{
  "voice": "zh-CN-YunxiaNeural",
  "lines": [
    { "id": "snow_white_0_1", "role": "narrate", "text": "白雪公主想去森林里看看，一个人走进了大树林。" },
    { "id": "snow_white_0_2", "role": "narrate", "text": "走呀走，她来到一座小小的木头房子前，屋里住着七个小矮人。" },
    { "id": "snow_white_0_3", "role": "白雪公主", "voice": "zh-TW-HsiaoYuNeural", "text": "这里好乱呀，我来帮小矮人们把家收拾好！" },
    { "id": "snow_white_0_4", "role": "narrate", "text": "白雪想帮忙，可要先数清楚——一共有几个小矮人呢？" },
    { "id": "snow_white_0_5", "role": "narrate", "text": "小朋友，我们一个一个点点看，数数一共有几个小矮人，好不好？" },
    { "id": "snow_white_0_6", "role": "博士", "voice": "zh-CN-YunyangNeural", "text": "我是博士，数数交给我最在行！" },
    { "id": "snow_white_0_7", "role": "乐乐", "voice": "zh-CN-YunxiNeural", "text": "我是乐乐，嘻嘻嘻，你好呀！" },
    { "id": "snow_white_0_8", "role": "困困", "voice": "zh-TW-YunJheNeural", "text": "我是困困……哈啊……好困哦。" },
    { "id": "snow_white_0_9", "role": "羞羞", "voice": "zh-TW-HsiaoChenNeural", "text": "我、我是羞羞……你别盯着我看啦。" },
    { "id": "snow_white_0_10", "role": "喷喷", "voice": "zh-CN-liaoning-XiaobeiNeural", "text": "我是喷喷，阿……阿嚏！" },
    { "id": "snow_white_0_11", "role": "气气", "voice": "zh-CN-YunjianNeural", "text": "哼，我是气气，数快点啦！" },
    { "id": "snow_white_0_12", "role": "迷糊", "voice": "zh-CN-shaanxi-XiaoniNeural", "text": "我是迷糊，咦，你点的是我吗？" },
    { "id": "snow_white_0_13", "role": "narrate", "text": "一个！" },
    { "id": "snow_white_0_14", "role": "narrate", "text": "两个！" },
    { "id": "snow_white_0_15", "role": "narrate", "text": "三个！" },
    { "id": "snow_white_0_16", "role": "narrate", "text": "四个！" },
    { "id": "snow_white_0_17", "role": "narrate", "text": "五个！" },
    { "id": "snow_white_0_18", "role": "narrate", "text": "六个！" },
    { "id": "snow_white_0_19", "role": "narrate", "text": "七个！" },
    { "id": "snow_white_0_20", "role": "narrate", "text": "这个我们数过啦，点点别的小矮人吧～" },
    { "id": "snow_white_0_21", "role": "narrate", "text": "一共有七个小矮人，全部数清楚啦！" },
    { "id": "snow_white_0_22", "role": "narrate", "text": "小矮人们饿啦，我们给每人盛一碗饭吧，一个小矮人一个碗，一个都不能少哦。" },
    { "id": "snow_white_0_23", "role": "博士", "voice": "zh-CN-YunyangNeural", "text": "谢谢你的碗，我要装满浆果！" },
    { "id": "snow_white_0_24", "role": "乐乐", "voice": "zh-CN-YunxiNeural", "text": "有饭吃啦，嘻嘻，谢谢你！" },
    { "id": "snow_white_0_25", "role": "困困", "voice": "zh-TW-YunJheNeural", "text": "嗯……谢谢……我吃一口就睡……" },
    { "id": "snow_white_0_26", "role": "羞羞", "voice": "zh-TW-HsiaoChenNeural", "text": "谢、谢谢你……我小声说谢谢。" },
    { "id": "snow_white_0_27", "role": "喷喷", "voice": "zh-CN-liaoning-XiaobeiNeural", "text": "谢谢你，阿嚏——哎呀吹到饭啦！" },
    { "id": "snow_white_0_28", "role": "气气", "voice": "zh-CN-YunjianNeural", "text": "哼，谢谢……其实我很开心啦。" },
    { "id": "snow_white_0_29", "role": "迷糊", "voice": "zh-CN-shaanxi-XiaoniNeural", "text": "咦，这碗是给我的吗？谢谢你！" },
    { "id": "snow_white_0_30", "role": "narrate", "text": "七个碗都盛好啦，七个小矮人一人一碗，正正好！" },
    { "id": "snow_white_0_31", "role": "白雪公主", "voice": "zh-TW-HsiaoYuNeural", "text": "谢谢你帮我数清楚小矮人，还给大家盛了饭，你真棒！" },

    { "id": "snow_white_1_1", "role": "narrate", "text": "从此白雪公主和七个小矮人成了好朋友，一起住在森林里的小木屋。" },
    { "id": "snow_white_1_2", "role": "博士", "voice": "zh-CN-YunyangNeural", "text": "多亏你帮忙，我们的家又整齐、大家又吃得饱饱的！" },
    { "id": "snow_white_1_3", "role": "白雪公主", "voice": "zh-TW-HsiaoYuNeural", "text": "小朋友，你陪我们过了好开心的一天！" },
    { "id": "snow_white_1_4", "role": "narrate", "text": "点点悄悄飞到你耳边，轻轻地问。" },
    { "id": "snow_white_1_5", "role": "narrate", "text": "小朋友，你愿意把白雪和七个小矮人的故事，讲给他们听一听吗？" },
    { "id": "snow_white_1_6", "role": "博士", "voice": "zh-CN-YunyangNeural", "text": "讲得真好听，谢谢你！" },
    { "id": "snow_white_1_7", "role": "narrate", "text": "从今天起，白雪和七个小矮人就住在这片森林里啦，随时欢迎你来玩。" }
  ]
}
