{
  "voice": "zh-CN-XiaoyiNeural",
  "lines": [
    {
      "id": "fairy_greet_1",
      "trigger": "greet",
      "cooldown": 99999,
      "text": "你好呀小朋友！我是小仙子，今天想去哪儿玩呀？"
    },
    {
      "id": "fairy_greet_2",
      "trigger": "greet",
      "cooldown": 99999,
      "text": "嘿嘿，我们又见面啦！"
    },
    {
      "id": "fairy_idle_1",
      "trigger": "idle",
      "cooldown": 60,
      "text": "啦啦啦，今天天气真好呀。"
    },
    {
      "id": "fairy_idle_2",
      "trigger": "idle",
      "cooldown": 60,
      "text": "你看天上的云朵，像不像棉花糖呀？"
    },
    {
      "id": "fairy_idle_3",
      "trigger": "idle",
      "cooldown": 60,
      "text": "唔…今天大家都在忙些什么呢。"
    },
    {
      "id": "fairy_idle_4",
      "trigger": "idle",
      "cooldown": 60,
      "text": "嗯哼，我就在你身边陪着你哟。"
    },
    {
      "id": "fairy_water_1",
      "trigger": "near_water",
      "cooldown": 90,
      "text": "前面是小池塘，小心别掉进去咯。"
    },
    {
      "id": "fairy_water_2",
      "trigger": "near_water",
      "cooldown": 90,
      "text": "哇，水里会不会有小鱼呀？"
    },
    {
      "id": "fairy_mountain_1",
      "trigger": "near_mountain",
      "cooldown": 90,
      "text": "好高的山呀！我们爬上去看看吧。"
    },
    {
      "id": "fairy_village_1",
      "trigger": "near_village",
      "cooldown": 90,
      "text": "这里是小村庄，房子好可爱呀。"
    },
    {
      "id": "fairy_poi_pond",
      "trigger": "poi_pond",
      "cooldown": 180,
      "text": "看！那边有个大池塘，我们过去看看吧！"
    },
    {
      "id": "fairy_poi_mountain",
      "trigger": "poi_mountain",
      "cooldown": 180,
      "text": "那边有座大山耶！要不要去爬爬看？"
    },
    {
      "id": "fairy_poi_windmill",
      "trigger": "poi_windmill",
      "cooldown": 180,
      "text": "快看！山坡上有个大风车，呼啦呼啦转呀转！"
    },
    {
      "id": "fairy_poi_marsh",
      "trigger": "poi_marsh",
      "cooldown": 180,
      "text": "小树林里藏着一个小水潭，我们去探险吧！"
    },
    {
      "id": "fairy_reward_1",
      "trigger": "reward",
      "cooldown": 5,
      "text": "哇！你做到啦，真棒！"
    },
    {
      "id": "fairy_reward_2",
      "trigger": "reward",
      "cooldown": 5,
      "text": "耶！得到一张新贴纸！"
    },
    {
      "id": "fairy_reward_3",
      "trigger": "reward",
      "cooldown": 5,
      "text": "你好厉害呀，继续加油哦！"
    },
    {
      "id": "fairy_cooldown_start_1",
      "trigger": "cooldown_start",
      "cooldown": 5,
      "text": "今天玩得好开心呀！先歇一歇，等小闹钟转满，我们再一起玩，好不好？"
    },
    {
      "id": "fairy_cooldown_start_2",
      "trigger": "cooldown_start",
      "cooldown": 5,
      "text": "玩了好久啦，眼睛要休息一下下哦，一会儿再来找我玩呀！"
    },
    {
      "id": "fairy_cooldown_end_1",
      "trigger": "cooldown_end",
      "cooldown": 5,
      "text": "休息好啦！我们继续一起玩吧！"
    },
    {
      "id": "fairy_guide_nudge_1",
      "trigger": "guide_nudge",
      "cooldown": 5,
      "text": "这边这边，快跟我来呀！"
    },
    {
      "id": "fairy_guide_nudge_2",
      "trigger": "guide_nudge",
      "cooldown": 5,
      "text": "跟上呀小朋友，就在前面啦！"
    },
    {
      "id": "fairy_guide_nudge_3",
      "trigger": "guide_nudge",
      "cooldown": 5,
      "text": "我在这儿等你哦，快过来～"
    },
    {
      "id": "fairy_guide_arrive_1",
      "trigger": "guide_arrive",
      "cooldown": 3,
      "text": "到啦到啦！就是这里～"
    },
    {
      "id": "fairy_guide_arrive_2",
      "trigger": "guide_arrive",
      "cooldown": 3,
      "text": "我们到咯，你看！"
    },
    {
      "id": "fairy_guide_cancel_1",
      "trigger": "guide_cancel",
      "cooldown": 3,
      "text": "好呀，那我们就不去啦。"
    },
    {
      "id": "fairy_guide_timeout_1",
      "trigger": "guide_timeout",
      "cooldown": 3,
      "text": "路好像有点远，我们下次再去吧～"
    },
    {
      "id": "fairy_guide_hint_1",
      "trigger": "guide_hint",
      "cooldown": 90,
      "text": "我认得好多好玩的地方哦…可惜没人陪我一起去。"
    },
    {
      "id": "fairy_guide_hint_2",
      "trigger": "guide_hint",
      "cooldown": 90,
      "text": "一个人飞来飞去的…要是有人跟我一块儿去探险就好啦。"
    },
    {
      "id": "fairy_guide_hint_3",
      "trigger": "guide_hint",
      "cooldown": 90,
      "text": "山那边、水那边…我都好想再去看看呢。"
    }
  ]
}
